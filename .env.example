# The project Priya orchestrates work for.
PRIYA_PROJECT_PATH=/home/prrockzed/MyProjects/AgentKavach

# Where Priya's Obsidian vault (long-term memory) lives. Separate from this repo on purpose.
PRIYA_VAULT_PATH=/home/prrockzed/MyProjects/priya-vault

# Daemon HTTP port.
PRIYA_PORT=4700

# SQLite database file (relative to daemon/ unless absolute).
PRIYA_DB_PATH=./priya.db

# Max parallel workers (git worktrees / claude -p sessions) at once.
PRIYA_CONCURRENCY=5
